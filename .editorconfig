# EditorConfig — https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Go — gofmt uses tabs
[*.go]
indent_style = tab
indent_size = 4

# JavaScript / JSX — eslint-config-standard (2-space, single quotes)
[*.{js,jsx}]
indent_style = space
indent_size = 2
quote_type = single

# JSON / Babel / ESLint configs — 4-space to match existing .eslintrc.json
[*.json]
indent_style = space
indent_size = 4

# SCSS — stylelint-config-standard-scss (2-space, double quotes)
[*.{scss,css}]
indent_style = space
indent_size = 2
quote_type = double

# Go templates
[*.tmpl]
indent_style = space
indent_size = 2

# YAML
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false
