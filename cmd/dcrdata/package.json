{
  "name": "dcrdata",
  "version": "1.1.0",
  "description": "[![Build Status](https://img.shields.io/travis/decred/dcrdata.svg)](https://travis-ci.org/decred/dcrdata) [![Latest tag](https://img.shields.io/github/tag/decred/dcrdata.svg)](https://github.com/decred/dcrdata/tags) [![Go Report Card](https://goreportcard.com/badge/github.com/decred/dcrdata)](https://goreportcard.com/report/github.com/decred/dcrdata) [![ISC License](https://img.shields.io/badge/license-ISC-blue.svg)](http://copyfree.org)",
  "main": "index.js",
  "private": true,
  "sideEffects": false,
  "scripts": {
    "build": "npm run format:check && npm run lint && npm run lint:css && webpack --config webpack.prod.cjs --progress --color",
    "test": "vitest run",
    "watch": "webpack --watch --config webpack.dev.cjs",
    "analyze": "webpack --config webpack.analyze.cjs",
    "format": "prettier --write \"public/**/*.{js,scss}\"",
    "format:check": "prettier --check \"public/**/*.{js,scss}\"",
    "lint": "eslint public/js public/index.js",
    "lint:fix": "eslint public/js public/index.js --fix",
    "lint:css": "stylelint \"public/scss/**/*.scss\" --config .stylelintrc",
    "lint:css:fix": "stylelint \"public/scss/**/*.scss\" --config .stylelintrc --fix"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/decred/dcrdata.git"
  },
  "keywords": [],
  "author": "The Decred developers",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/decred/dcrdata/issues"
  },
  "homepage": "https://github.com/decred/dcrdata#readme",
  "vitest": {
    "environment": "jsdom",
    "include": [
      "public/js/**/*.test.js"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.21.3",
    "@babel/plugin-syntax-dynamic-import": "^7.8.3",
    "@babel/preset-env": "^7.20.2",
    "@eslint/js": "^9.0.0",
    "@hotwired/stimulus": "^3.2.1",
    "@hotwired/stimulus-webpack-helpers": "^1.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "babel-loader": "^9.1.2",
    "clean-webpack-plugin": "^4.0.0",
    "css-loader": "^6.7.3",
    "css-minimizer-webpack-plugin": "^4.2.2",
    "eslint": "^9.0.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-webpack-plugin": "^5.0.0",
    "fast-check": "^4.6.0",
    "jsdom": "^29.0.1",
    "mini-css-extract-plugin": "^2.7.5",
    "mousetrap": "^1.6.5",
    "prettier": "^3.8.1",
    "sass": "^1.59.3",
    "sass-loader": "^13.2.1",
    "stylelint": "^16.0.0",
    "stylelint-config-standard-scss": "^13.1.0",
    "stylelint-webpack-plugin": "^5.1.0",
    "vitest": "^4.1.0",
    "webpack": "^5.76.3",
    "webpack-bundle-analyzer": "^4.8.0",
    "webpack-cli": "^5.0.1",
    "webpack-manifest-plugin": "^6.0.1",
    "webpack-merge": "^5.8.0"
  },
  "dependencies": {
    "bootstrap": "^5.3.8",
    "dompurify": "^3.3.0",
    "lodash-es": "^4.17.21",
    "qrcode": "^1.5.1",
    "regenerator-runtime": "^0.14.1",
    "url-parse": "^1.5.10"
  }
}
